# 元枢智能物联系统【mtrk】 - 环境变量配置
# 复制为 .env 后修改
#   cp .env.example .env

# ==========================================
# 必填 — JWT 签名密钥
# ==========================================
# 生成命令: openssl rand -base64 32
JWT_SECRET=your-secret-key-change-this-in-production

# ==========================================
# MQTT 连接配置
# ==========================================
# Broker 地址
MQTT_BROKER=d11aab19.ala.cn-hangzhou.emqxsl.cn
# 端口: 8040(WebSocket TLS) / 8083(WebSocket) / 8883(TLS加密) / 1883(普通TCP)
MQTT_PORT=8040
# 协议: wss / ws / ssl / tcp
MQTT_PROTOCOL=wss
# WebSocket 路径（仅 ws/wss 协议生效，TCP 忽略此参数）
MQTT_PATH=/mqtt
# 认证用户名
MQTT_USERNAME=taiyi
# 认证密码
MQTT_PASSWORD=p9UPpz2i.H48stE

# ==========================================
# 数据库（可选 — 默认值即可使用）
# ==========================================
# 是否启用自动备份
DB_BACKUP_ENABLE=true
# 备份间隔（小时）
DB_BACKUP_HOURS=24
# ==========================================
# IoT Manager - Environment Variables Example
# ==========================================
# Copy this file to .env and modify the values as needed
# DO NOT commit .env file to version control with real secrets!

# ==========================================
# Server Configuration
# ==========================================
SERVER_HOST=0.0.0.0
SERVER_PORT=6116

# ==========================================
# HTTPS Configuration (optional)
# ==========================================
HTTPS_ENABLE=false
HTTPS_CERT=./certs/cert.pem
HTTPS_KEY=./certs/key.pem

# ==========================================
# CORS Configuration (optional)
# ==========================================
# Comma-separated list of allowed origins
# Use "*" to allow all origins (not recommended for production)
# Example: CORS_ALLOWED_ORIGINS=https://your-domain.com,http://localhost:5173
CORS_ALLOWED_ORIGINS=

# ==========================================
# MQTT Configuration (required for device control)
# ==========================================
MQTT_BROKER=d11aab19.ala.cn-hangzhou.emqxsl.cn
MQTT_PORT=8883
MQTT_PROTOCOL=ssl
MQTT_TLS_ENABLED=true
MQTT_CLIENT_ID_PREFIX=iot-manager-
MQTT_USERNAME=your-mqtt-username-here
MQTT_PASSWORD=your-mqtt-password-here

# ==========================================
# Database Configuration
# ==========================================
DB_PATH=./data/iot.db
DB_BACKUP_ENABLE=false
DB_BACKUP_PATH=./data/backup
DB_BACKUP_HOURS=24

# ==========================================
# JWT Security Configuration (IMPORTANT!)
# ==========================================
# Generate a strong secret key for production using:
# openssl rand -base64 32
JWT_SECRET=your-very-secure-secret-key-change-in-production-please!
JWT_EXPIRES_HOURS=24

# ==========================================
# Grafana Configuration (only for full deployment)
# ==========================================
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=change-this-in-production-please!

# ==========================================
# Notes
# ==========================================
# 1. For production deployment, you MUST change JWT_SECRET and all passwords!
# 2. MQTT_USERNAME and MQTT_PASSWORD are required to connect to the broker
# 3. DB_BACKUP_ENABLE is recommended to prevent data loss
# 4. For HTTPS, use Let's Encrypt for free certificates
